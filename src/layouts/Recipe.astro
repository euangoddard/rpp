---
import type { CollectionEntry } from "astro:content";
import Base from "./Base.astro";
import Categories from "../components/Categories.astro";
import StoreRecentRecipe from "../components/StoreRecentRecipe.tsx";
import StarRecipe from "../components/StarRecipe.tsx";
import CookMode from "../components/CookMode.tsx";
import { buildPermalink } from "../lib/permalink";

interface Props {
  recipe: CollectionEntry<"recipes">;
}

const { recipe } = Astro.props;
const { title, serves, tags, prep, cook, source } = recipe.data;
const permalink = buildPermalink(`/recipes/${recipe.id}`);
const recipeSynopsis = { title, url: `/recipes/${recipe.id}` };

const metaParts = [
  `Serves ${serves}`,
  prep && `Prep ${prep}`,
  cook && `Cook ${cook}`,
].filter(Boolean);

const descriptionParts = [
  [`Serves ${serves}`, prep && `prep ${prep}`, cook && `cook ${cook}`]
    .filter(Boolean)
    .join(", "),
  tags.length > 0 ? `Categories: ${tags.join(", ")}` : null,
].filter(Boolean) as string[];
const description = descriptionParts.join(". ");
---

<Base {title} {description} {permalink}>
  <article>
    <StoreRecentRecipe recipe={recipeSynopsis} client:idle />
    <header class="mb-7">
      <div class="flex items-start justify-between gap-3">
        <h1 class="text-4xl sm:text-[2.75rem]">{title}</h1>
        <StarRecipe client:load recipe={recipeSynopsis} />
      </div>
      <p class="meta-label border-line mt-4 border-b pb-4">
        {metaParts.join(" · ")}
      </p>
    </header>

    <section class="recipe-prose">
      <slot />
    </section>

    {
      source && (
        <p class="mt-8" data-hide-when-cooking>
          <a
            href={source}
            rel="noopener"
            class="text-accent text-sm underline underline-offset-2"
          >
            Original recipe ↗
          </a>
        </p>
      )
    }

    <aside
      class="border-line mt-12 border-t pt-5 pb-6"
      data-hide-when-cooking
      data-hide-in-print
    >
      <h2 class="meta-label mb-3 font-sans">Categories</h2>
      <Categories categories={tags} />
    </aside>

    <CookMode client:idle />
  </article>
</Base>
