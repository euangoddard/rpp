---
import type { Page } from "astro";
import { ChevronLeftIcon, ChevronRightIcon } from "./icons";

interface Props {
  page: Page<unknown>;
}

const { page } = Astro.props;
const linkClass =
  "text-accent hover:bg-paper-deep flex size-9 items-center justify-center rounded-full transition-colors";
const disabledClass =
  "text-ink-soft/40 flex size-9 items-center justify-center";
---

<nav class="mt-10 flex items-center justify-center gap-3" aria-label="Pages">
  {
    page.url.prev ? (
      <a href={page.url.prev} class={linkClass} aria-label="Previous page">
        <ChevronLeftIcon class="size-5" />
      </a>
    ) : (
      <span class={disabledClass}>
        <ChevronLeftIcon class="size-5" />
      </span>
    )
  }
  <span class="meta-label">
    Page {page.currentPage} of {page.lastPage}
  </span>
  {
    page.url.next ? (
      <a href={page.url.next} class={linkClass} aria-label="Next page">
        <ChevronRightIcon class="size-5" />
      </a>
    ) : (
      <span class={disabledClass}>
        <ChevronRightIcon class="size-5" />
      </span>
    )
  }
</nav>
