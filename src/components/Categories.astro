---
export interface Props {
  categories: readonly string[];
}
import { getTagUrl } from "../lib/tags";

const { categories } = Astro.props;
---

<nav class="inline-flex flex-wrap gap-1.5">
  {
    categories.map((cat) => (
      <a
        class="border-line bg-paper-deep text-ink-soft hover:border-accent hover:text-accent rounded-full border px-3 py-1 text-[0.8125rem] font-medium transition-colors"
        href={getTagUrl(cat)}
      >
        {cat}
      </a>
    ))
  }
</nav>
