{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rpp",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
  },
  "routes": [
    {
      "pattern": "recipes.euans.space",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
